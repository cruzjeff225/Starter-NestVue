generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  idRol       Int          @id @default(autoincrement())
  nombre      String       @unique
  usuarios    Usuario[]
  permisos    RolPermiso[]
}

model Permiso {
  idPermiso Int          @id @default(autoincrement())
  nombre    String       @unique
  roles     RolPermiso[]
}

model RolPermiso {
  rolId     Int
  permisoId Int
  rol       Rol     @relation(fields: [rolId], references: [idRol])
  permiso   Permiso @relation(fields: [permisoId], references: [idPermiso])

  @@id([rolId, permisoId])
}

model Usuario {
  idUsuario  Int      @id @default(autoincrement())
  nombre     String
  email      String   @unique
  contraseña String
  rolId      Int
  activo     Boolean  @default(true)
  rol        Rol      @relation(fields: [rolId], references: [idRol])
  creadoEn   DateTime @default(now())
}

model Cliente {
  idCliente    Int           @id @default(autoincrement())
  nombre       String
  apellido     String
  email        String        @unique
  telefono     String
  direccion    String
  departamento String
  municipio    String
  distrito     String
  dui          String        @unique  // Documento de identidad
  activo       Boolean       @default(true)
  creadoEn     DateTime      @default(now())
  reservaciones Reservacion[]
}

model Reservacion {
  idReservacion Int       @id @default(autoincrement())
  fecha         DateTime
  descripcion   String?
  activo        Boolean   @default(true)
  clienteId     Int
  cliente       Cliente   @relation(fields: [clienteId], references: [idCliente])

  @@index([clienteId])
}