generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  idRol    Int          @id @default(autoincrement())
  nombre   String       @unique
  usuarios Usuario[]
  permisos RolPermiso[]
}

model Permiso {
  idPermiso Int          @id @default(autoincrement())
  nombre    String       @unique
  roles     RolPermiso[]
}

model RolPermiso {
  rolId     Int
  permisoId Int

  rol     Rol     @relation(fields: [rolId], references: [idRol])
  permiso Permiso @relation(fields: [permisoId], references: [idPermiso])

  @@id([rolId, permisoId])
}

model Usuario {
  idUsuario   Int      @id @default(autoincrement())
  nombre      String
  email       String   @unique
  contraseña String
  rolId       Int
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  rol Rol @relation(fields: [rolId], references: [idRol])
}

//////////////////////////////////////////////////////////
// 🏨 ROOMS
//////////////////////////////////////////////////////////

model Room {
  id     String     @id @default(uuid())
  number String     @unique
  floor  Int
  price  Float
  status RoomStatus @default(AVAILABLE)

  typeId String
  type   RoomType @relation(fields: [typeId], references: [id])

  reservas Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([typeId])
}

model RoomType {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  capacity    Int

  rooms Room[]
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

//////////////////////////////////////////////////////////
// 👤 CUSTOMERS
//////////////////////////////////////////////////////////

model Customer {
  id       Int      @id @default(autoincrement())
  nombre   String
  email    String   @unique
  telefono String
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  // 📍 Dirección estructurada
  departamento String
  municipio    String
  distrito     String
  direccion    String

  reservas Reservation[]

  @@map("customers")
}

//////////////////////////////////////////////////////////
// 📅 RESERVATIONS (CLAVE DEL SISTEMA)
//////////////////////////////////////////////////////////

model Reservation {
  id String @id @default(uuid())

  customerId Int
  roomId     String

  checkIn  DateTime
  checkOut DateTime

  status    ReservationStatus @default(RESERVED)
  createdAt DateTime          @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  room     Room     @relation(fields: [roomId], references: [id])

  // 🔥 ÍNDICES CRÍTICOS
  @@index([roomId])
  @@index([customerId])
  @@index([checkIn, checkOut])
  // 🔥 BASE PARA VALIDAR DISPONIBILIDAD
  @@index([roomId, checkIn, checkOut])
  
}

//////////////////////////////////////////////////////////
// 📊 ESTADO DE RESERVA
//////////////////////////////////////////////////////////

enum ReservationStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}