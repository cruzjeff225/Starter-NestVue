generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  idRol       Int          @id @default(autoincrement())
  nombre      String       @unique
  usuarios    Usuario[]
  permisos    RolPermiso[]
}

model Permiso {
  idPermiso Int          @id @default(autoincrement())
  nombre    String       @unique
  roles     RolPermiso[]
}

model RolPermiso {
  rolId     Int
  permisoId Int
  rol       Rol     @relation(fields: [rolId], references: [idRol])
  permiso   Permiso @relation(fields: [permisoId], references: [idPermiso])

  @@id([rolId, permisoId])
}

model Usuario {
  idUsuario  Int      @id @default(autoincrement())
  nombre     String
  email      String   @unique
  contraseña String
  rolId      Int
  activo     Boolean  @default(true)
  rol        Rol      @relation(fields: [rolId], references: [idRol])
  creadoEn   DateTime @default(now())
}

model Cliente {
  idCliente    Int           @id @default(autoincrement())
  nombre       String
  apellido     String
  email        String        @unique
  telefono     String
  direccion    String
  departamento String
  municipio    String
  distrito     String
  dui          String        @unique  // Documento de identidad
  activo       Boolean       @default(true)
  creadoEn     DateTime      @default(now())
  reservaciones Reservacion[]
}

enum EstadoHabitacion {
  disponible
  ocupada
  reservada
  mantenimiento
}

model TipoHabitacion {
  idTipo       Int          @id @default(autoincrement())
  nombre       String       @unique   // "Suite", "Doble", "Simple"
  precioBase   Decimal      @db.Decimal(10, 2)
  descripcion  String?
  habitaciones Habitacion[]
}

model Habitacion {
  idHabitacion Int               @id @default(autoincrement())
  numero       String            @unique   // "101", "202-A"
  piso         Int
  capacidad    Int               @default(2)
  estado       EstadoHabitacion  @default(disponible)
  amenidades   String[]          // ["wifi", "AC", "TV", "jacuzzi"]
  imagenUrl    String?
  descripcion  String?
  activo       Boolean           @default(true)
  tipoId       Int
  tipo         TipoHabitacion    @relation(fields: [tipoId], references: [idTipo])
  reservaciones Reservacion[]
  creadoEn     DateTime          @default(now())
}

enum EstadoReservacion {
  pendiente
  confirmada
  en_curso
  completada
  cancelada
  no_show
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
  otro
}

model Reservacion {
  idReservacion    Int                @id @default(autoincrement())
  fechaEntrada     DateTime
  fechaSalida      DateTime
  numHuespedes     Int                @default(1)
  estado           EstadoReservacion  @default(pendiente)
  metodoPago       MetodoPago         @default(efectivo)
  precioNoche      Decimal            @db.Decimal(10, 2)
  descuento        Decimal            @default(0) @db.Decimal(5, 2)  // porcentaje 0-100
  totalCalculado   Decimal            @db.Decimal(10, 2)
  notas            String?
  motivoCancelacion String?
  clienteId        Int
  habitacionId     Int
  cliente          Cliente            @relation(fields: [clienteId], references: [idCliente])
  habitacion       Habitacion         @relation(fields: [habitacionId], references: [idHabitacion])
  creadoEn         DateTime           @default(now())
}